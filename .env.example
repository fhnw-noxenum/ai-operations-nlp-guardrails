# ============================================================================
#  NeMo Guardrails Lab - Environment
#  Copy this file to `.env` and edit the values.
# ============================================================================

# Which LLM should the rails call into? One of: openai | vllm
LLM_PROVIDER=openai


# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini


# --- vLLM (any OpenAI-compatible endpoint, hosted elsewhere) ---------------
# Paste in the URL of your vLLM server. Must end with /v1.
#   e.g.  http://gpu-box.lab.internal:8000/v1
#         https://vllm.mycompany.com/v1
VLLM_BASE_URL=https://your-vllm-host.example.com/v1
VLLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# vLLM usually doesn't require a key, but the OpenAI SDK insists on having one.
# Set it to whatever your vLLM server expects, or leave as EMPTY.
VLLM_API_KEY=EMPTY
